# ── Build output ─────────────────────────────────────────────────────────────
dist/
build/

# ── Node dependencies ─────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Test artefacts ────────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Editor / OS junk ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# ── Environment secrets (never bake into images) ─────────────────────────────
.env
.env.*
!.env.example

# ── Git ───────────────────────────────────────────────────────────────────────
.git/
.gitignore

# ── Docs (not needed at runtime) ─────────────────────────────────────────────
*.md
docs/
